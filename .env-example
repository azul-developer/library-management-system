DB_URL=jdbc:postgresql://postgres:5432/library_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

SERVER_PORT=8080

# When true the helper script will run the integration tests instead of the app
# Set to 'true' to execute tests automatically: RUN_TESTS=true
RUN_TESTS=false

# Seeding defaults
APP_SEED_ENABLED=false
# Comma-separated list: ROLE,USER,BOOK,ALL (empty = default: ROLE)
APP_SEED_TYPES=
# Default profile (override to 'dev' to run seeders annotated with @Profile("dev"))
SPRING_PROFILES_ACTIVE=local
LOAN_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/loan_db?sslmode=disable

# JWT config used by library-service
JWT_SECRET=your-jwt-secret
JWT_EXPIRATION=86400000
